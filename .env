# DotsBar environment variables

# Required: JWT secret (must be set to a strong random value)
JWT_SECRET=change_me_to_a_long_random_secret

# Mongo (NOT required if you run Firebase-only, but harmless)
MONGODB_URI=mongodb://localhost:27017/dotsbar

# Sports widget (optional)
SPORTS_API_KEY=your_api_key_here
SPORTS_API_HOST=api-football-v1.p.rapidapi.com
SPORTS_LEAGUE_ID=39
SPORTS_SEASON=2025

# Firebase Admin service account configuration
# IMPORTANT: backend/firebase.js uses firebase-admin (server-side).
# Place the downloaded Admin service account private key JSON in the repo root.
# Default expected path: ./serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# If you prefer Application Default Credentials instead of service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-credentials.json


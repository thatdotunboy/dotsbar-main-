# Copy this file to .env and fill in your own keys

MONGODB_URI=mongodb://127.0.0.1:27017/dotsbar
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=*
SPORTS_API_KEY=your_api_key_here
SPORTS_API_HOST=api-football-v1.p.rapidapi.com
SPORTS_LEAGUE_ID=39
SPORTS_SEASON=2025

# Firebase service account configuration
# Option 1: load a local service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# Option 2: use a JSON string in an environment variable
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Option 3: use Application Default Credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
